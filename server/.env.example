# Copy to server/.env and fill in. Never commit the real .env.

# --- Server ---
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed browser origins.
# Must include the Vite dev server URL or the client's cookies/requests will be blocked.
CORS_ORIGIN=http://localhost:5173

# --- Database ---
# Local: mongodb://127.0.0.1:27017/proflow
# Atlas: mongodb+srv://<user>:<pass>@<cluster>/proflow?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/proflow

# Set to "true" to boot the API without connecting to MongoDB (health checks only).
SKIP_DB=false

# --- Auth ---
# Two DIFFERENT random secrets. Generate each with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Token lifetimes in seconds. Defaults: 15 minutes / 7 days.
ACCESS_TOKEN_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_EXPIRES_IN_SECONDS=604800
